PORT=8086
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASS=password123
DB_NAME=microservices_db
DB_POOL_MAX=10

RABBITMQ_URL=amqp://admin:admin123@localhost:5672
RABBITMQ_EXCHANGE=ecommerce.events
RABBITMQ_EXCHANGE_TYPE=topic

NOTIFICATION_CONSUMER_ENABLED=true
NOTIFICATION_CONSUMER_QUEUE=notification.events
NOTIFICATION_CONSUMER_ROUTING_KEYS=order.*,fulfillment.*,review.*,chat.*,catalog.*
NOTIFICATION_CONSUMER_PREFETCH=20
NOTIFICATION_CONSUMER_RECONNECT_MS=5000
