PORT=8083
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASS=password123
DB_NAME=microservices_db
DB_POOL_MAX=10
RABBITMQ_URL=amqp://admin:admin123@localhost:5672
RABBITMQ_EXCHANGE=ecommerce.events
RABBITMQ_EXCHANGE_TYPE=topic
OUTBOX_PUBLISHER_ENABLED=true
OUTBOX_PUBLISHER_POLL_MS=3000
OUTBOX_PUBLISHER_BATCH_SIZE=50
FULFILLMENT_CONSUMER_ENABLED=true
FULFILLMENT_CONSUMER_QUEUE=ordering.fulfillment-events
FULFILLMENT_CONSUMER_ROUTING_KEYS=fulfillment.seller-confirmed,fulfillment.delivery.updated,fulfillment.completed
FULFILLMENT_CONSUMER_PREFETCH=20
FULFILLMENT_CONSUMER_RECONNECT_MS=5000
