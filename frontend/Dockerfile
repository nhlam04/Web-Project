FROM node:20-alpine AS build

WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
ARG VITE_ORDERING_URL=/api/ordering
ARG VITE_CATALOG_URL=/api/catalog
ARG VITE_AUTH_URL=/api/auth
ARG VITE_FULFILLMENT_URL=/api/fulfillment
ARG VITE_NOTIFICATION_URL=/api/notification
ARG VITE_REVIEW_URL=/api/reviews
ENV VITE_ORDERING_URL=$VITE_ORDERING_URL
ENV VITE_CATALOG_URL=$VITE_CATALOG_URL
ENV VITE_AUTH_URL=$VITE_AUTH_URL
ENV VITE_FULFILLMENT_URL=$VITE_FULFILLMENT_URL
ENV VITE_NOTIFICATION_URL=$VITE_NOTIFICATION_URL
ENV VITE_REVIEW_URL=$VITE_REVIEW_URL
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
